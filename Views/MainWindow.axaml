<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:BLIS_NG.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="360"
    x:CompileBindings="True"
    x:DataType="vm:MainWindowViewModel"
    x:Class="BLIS_NG.Views.MainWindow"
    Title="{Binding ServerControlViewModel.AppVersion}"
    WindowState="{Binding WindowState}"
    Padding="10"
    Height="360"
    Width="640"
    CanResize="False">

    <!--We
    are using Compiled bindings. This is not mandatory but makes life easier. Read more about it
    here:-->
    <!-- https://docs.avaloniaui.net/docs/basics/data/data-binding/compiled-bindings -->

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

	<Grid
        DataContext="{Binding ServerControlViewModel}"
        ColumnDefinitions="*"
        RowDefinitions="Auto,Auto,Auto,Auto,*,Auto"
    >
        <TextBlock
            Text="{Binding AppTitle}"
            TextAlignment="Left"
            FontWeight="Normal"
            FontSize="34"
            TextWrapping="Wrap"
            MaxHeight="92"
            Margin="0,4,0,6"
            Grid.Row="0"
            Grid.Column="0"
        />

        <TextBlock
            TextAlignment="Left"
            FontSize="18"
            Text="{Binding AppVersion}"
            Margin="0,0,0,18"
            Grid.Row="1"
            Grid.Column="0"
        />

        <TextBlock
            FontSize="24"
            FontFamily="Times New Roman"
            Foreground="#00AA00"
            Text="{Binding AppTagline}"
            TextWrapping="Wrap"
            Margin="0,0,0,12"
            Grid.Row="2"
            Grid.Column="0"
        />


        <TextBlock
            Text="{Binding AppLicenseNotice}"
            FontSize="12"
            FontFamily="Times New Roman"
            TextWrapping="Wrap"
            Grid.Column="0"
            Grid.Row="3"
        />

        <Grid
            Grid.Row="5"
            Grid.Column="0"
            Margin="0,12,0,0"
            RowDefinitions="Auto,Auto"
            RowSpacing="8"
        >
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" Grid.Row="0">
                <TextBlock VerticalAlignment="Center" Text="{Binding LanguageLabel}" />
                <ComboBox Width="110"
                          ItemsSource="{Binding AvailableLanguages}"
                          SelectedItem="{Binding SelectedLanguage}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock VerticalAlignment="Center"
                           Text="{Binding Status}" />
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Right">
                <Button Width="110" Height="40"
                        Command="{Binding StartServerCommand}"
                        IsEnabled="{Binding StartBlisEnabled}"
                        Content="{Binding StartBlisText}" />
                <Button Width="110" Height="40"
                        Command="{Binding StopServerCommand}"
                        IsEnabled="{Binding StopBlisEnabled}"
                        Content="{Binding StopBlisText}" />
                <Button Content="More Options" Width="110" Height="40" VerticalContentAlignment="Center">
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuItem Header="Update with ZIP File"
                                      Command="{Binding SelectZipCommand}" />
                            <Separator />
                            <MenuItem Header="Reset Password"
                                      Command="{Binding OpenPasswordResetCommand}" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
