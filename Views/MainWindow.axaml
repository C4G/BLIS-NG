<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:BLIS_NG.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="360"
    x:CompileBindings="True"
    x:DataType="vm:MainWindowViewModel"
    x:Class="BLIS_NG.Views.MainWindow"
    Title="{Binding ServerControlViewModel.AppVersion}"
    WindowState="{Binding WindowState}"
    Padding="10"
    Height="360"
    Width="640"
    CanResize="False">

    <!--We
    are using Compiled bindings. This is not mandatory but makes life easier. Read more about it
    here:-->
    <!-- https://docs.avaloniaui.net/docs/basics/data/data-binding/compiled-bindings -->

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid
        DataContext="{Binding ServerControlViewModel}"
        ColumnDefinitions="*"
        RowDefinitions="Auto,Auto,Auto,Auto,*,Auto"
    >
        <TextBlock
            Text="{Binding AppTitle}"
            TextAlignment="Left"
            FontWeight="Normal"
            FontSize="34"
            TextWrapping="Wrap"
            MaxHeight="92"
            Margin="0,4,0,6"
            Grid.Row="0"
            Grid.Column="0"
        />

        <TextBlock
            TextAlignment="Left"
            FontSize="18"
            Text="{Binding AppVersion}"
            Margin="0,0,0,18"
            Grid.Row="1"
            Grid.Column="0"
        />

        <TextBlock
            FontSize="24"
            FontFamily="Times New Roman"
            Foreground="#00AA00"
            Text="{Binding AppTagline}"
            TextWrapping="Wrap"
            Margin="0,0,0,12"
            Grid.Row="2"
            Grid.Column="0"
        />

        <TextBlock
            Text="{Binding AppLicenseNotice}"
            FontSize="12"
            FontFamily="Times New Roman"
            TextWrapping="Wrap"
            Grid.Column="0"
            Grid.Row="3"
        />

        <Grid
            Grid.Row="5"
            Grid.Column="0"
            Margin="0,12,0,0"
            ColumnDefinitions="Auto,*,Auto"
            VerticalAlignment="Center"
        >
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center" Text="{Binding LanguageLabel}" />
                <ComboBox MinWidth="95"
                          ItemsSource="{Binding AvailableLanguages}"
                          SelectedItem="{Binding SelectedLanguage}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <TextBlock Grid.Column="1"
                       Margin="24,0,24,0"
                       VerticalAlignment="Center"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding Status}" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button MinWidth="120"
                        Padding="12,6"
                        Command="{Binding StartServerCommand}"
                        IsEnabled="{Binding StartBlisEnabled}"
                        Content="{Binding StartBlisText}" />
                <Button MinWidth="120"
                        Padding="12,6"
                        Command="{Binding StopServerCommand}"
                        IsEnabled="{Binding StopBlisEnabled}"
                        Content="{Binding StopBlisText}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
