<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:BLIS_NG.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="360"
    x:CompileBindings="True"
    x:DataType="vm:MainWindowViewModel"
    x:Class="BLIS_NG.Views.MainWindow"
    Title="{Binding ServerControlViewModel.AppVersion}"
    WindowState="{Binding WindowState}"
    Padding="10"
    Height="360"
    Width="640"
    CanResize="False">

    <!--
    We are using Compiled bindings. This is not mandatory but makes life easier. 
    Read more about it here:
    -->
    <!-- https://docs.avaloniaui.net/docs/basics/data/data-binding/compiled-bindings -->

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <!-- 
    ShowGridLines="true" can be added below to make debugging easier.
    -->
    <Grid
        DataContext="{Binding ServerControlViewModel}"
        ColumnDefinitions="*"
        RowDefinitions="Auto,Auto,Auto,Auto,*,Auto"
    >
        <TextBlock
            Text="{Binding AppTitle}"
            TextAlignment="Left"
            FontWeight="Normal"
            FontSize="34"
            TextWrapping="Wrap"
            MaxHeight="92"
            Margin="0,4,0,6"
            Grid.Row="0"
            Grid.Column="0"
        />

        <TextBlock
            TextAlignment="Left"
            FontSize="18"
            Text="{Binding AppVersion}"
            Margin="0,0,0,18"
            Grid.Row="1"
            Grid.Column="0"
        />

        <TextBlock
            FontSize="24"
            FontFamily="Times New Roman"
            Foreground="#00AA00"
            Text="{Binding AppTagline}"
            TextWrapping="Wrap"
            Margin="0,0,0,12"
            Grid.Row="2"
            Grid.Column="0"
        />


        <TextBlock
            Text="{Binding AppLicenseNotice}"
            FontSize="12"
            FontFamily="Times New Roman"
            TextWrapping="Wrap"
            Grid.Column="0"
            Grid.Row="3"
        />

        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center"
            Grid.Row="4">
            <TextBlock VerticalAlignment="Center"
                Text="{Binding Status}" />
        </StackPanel>

        <Panel Grid.Row="5">
            <ComboBox Width="110"
                HorizontalAlignment="Left"
                ItemsSource="{Binding AvailableLanguages}"
                SelectedItem="{Binding SelectedLanguage}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

            <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="10"
                VerticalAlignment="Center" HorizontalAlignment="Right">

                <Button Width="110" Height="40"
                    Command="{Binding StartServerCommand}"
                    IsEnabled="{Binding StartBlisEnabled}"
                    Content="{Binding StartBlisText}"
                    VerticalContentAlignment="Center" />
                <Button Width="110" Height="40"
                    Command="{Binding StopServerCommand}"
                    IsEnabled="{Binding StopBlisEnabled}"
                    Content="{Binding StopBlisText}"
                    VerticalContentAlignment="Center" />
                <DropDownButton Content="{Binding MoreOptionsText}" Width="150" Height="40"
                    VerticalContentAlignment="Center">
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuItem Header="{Binding UpdateWithZipFileText}"
                                Command="{Binding SelectZipCommand}"
                                IsVisible="{Binding SelfUpdateEnabled}" />
                            <Separator IsVisible="{Binding SelfUpdateEnabled}" />
                            <MenuItem Header="{Binding ResetPasswordText}"
                                Command="{Binding OpenPasswordResetCommand}" />
                        </MenuFlyout>
                    </Button.Flyout>
                </DropDownButton>
            </StackPanel>
        </Panel>
    </Grid>
</Window>
