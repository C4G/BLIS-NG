<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:BLIS_NG.ViewModels"
    xmlns:lang="using:BLIS_NG.Lang"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="240"
    x:CompileBindings="True"
    x:DataType="vm:PasswordResetViewModel"
    x:Class="BLIS_NG.Views.PasswordResetDialog"
    Title="{x:Static lang:Resources.ResetPassword}"
    Width="360"
    Height="320"
    CanResize="False"
    WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20" Spacing="12">

        <TextBlock FontSize="18" FontWeight="Bold"
            Text="{x:Static lang:Resources.ResetUserPassword}" />

        <StackPanel Spacing="4">
            <TextBlock Text="{x:Static lang:Resources.Username}" />
            <TextBox Text="{Binding Username}"
                PlaceholderText="{x:Static lang:Resources.EnterUsername}" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="{x:Static lang:Resources.NewPassword}" />
            <TextBox Text="{Binding NewPassword}" PasswordChar="●"
                PlaceholderText="{x:Static lang:Resources.EnterNewPasswordShort}" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="{x:Static lang:Resources.ConfirmPassword}" />
            <TextBox Text="{Binding ConfirmPassword}" PasswordChar="●"
                PlaceholderText="{x:Static lang:Resources.ConfirmNewPassword}" />
        </StackPanel>

        <TextBlock Foreground="Red" Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" />
        <TextBlock Foreground="Green" Text="{Binding SuccessMessage}"
            IsVisible="{Binding HasSuccess}" />

        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <Button Width="100" Command="{Binding ProceedToVerifyCommand}"
                Content="{x:Static lang:Resources.ButtonReset}" />
            <Button Width="100" Command="{Binding CancelCommand}"
                Content="{x:Static lang:Resources.ButtonCancel}" />
        </StackPanel>

    </StackPanel>
</Window>