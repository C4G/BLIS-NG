<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BLIS_NG.ViewModels"
        xmlns:lang="using:BLIS_NG.Lang"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="600"
        x:CompileBindings="True"
        x:DataType="vm:ToolsWindowViewModel"
        x:Class="BLIS_NG.Views.ToolsWindow"
        Title="{x:Static lang:Resources.ToolsWindowTitle}"
        Width="480"
        Height="620"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <DockPanel>

    <Border DockPanel.Dock="Top" Background="#005A9C" Padding="16 12">
      <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold"
                 Text="{x:Static lang:Resources.ToolsWindowTitle}"/>
    </Border>

    <TabControl>

      <!-- Password Reset Tab -->
      <TabItem Header="{x:Static lang:Resources.TabPasswordReset}">
        <ScrollViewer>
          <StackPanel Margin="20" Spacing="12"
                      DataContext="{Binding PasswordResetViewModel}">

            <TextBlock FontSize="16" FontWeight="Bold"
                       Text="{x:Static lang:Resources.ResetUserPassword}"/>

            <!-- Step 1: Target user details -->
            <StackPanel Spacing="10" IsVisible="{Binding IsStep1Visible}">

              <StackPanel Spacing="4">
                <TextBlock Text="{x:Static lang:Resources.UsernameToReset}"/>
                <TextBox Text="{Binding Username}"
                         Watermark="{x:Static lang:Resources.EnterUsername}"/>
              </StackPanel>

              <!-- Password requirements box -->
              <Border Background="#E3F2FD" CornerRadius="4" Padding="10">
                <StackPanel Spacing="4">
                  <TextBlock FontWeight="SemiBold" Foreground="#0D47A1"
                             Text="{x:Static lang:Resources.PasswordRequirements}"/>
                  <TextBlock Foreground="#1565C0" FontSize="12"
                             Text="{x:Static lang:Resources.PasswordReqLength}"/>
                  <TextBlock Foreground="#1565C0" FontSize="12"
                             Text="{x:Static lang:Resources.PasswordReqClasses}"/>
                  <TextBlock Foreground="#1565C0" FontSize="12"
                             Text="{x:Static lang:Resources.PasswordReqSymbols}"/>
                </StackPanel>
              </Border>

              <StackPanel Spacing="4">
                <TextBlock Text="{x:Static lang:Resources.NewPassword}"/>
                <TextBox Text="{Binding NewPassword}" PasswordChar="●"
                         Watermark="{x:Static lang:Resources.EnterNewPassword}"/>

                <!-- Strength meter -->
                <StackPanel Spacing="2" IsVisible="{Binding NewPassword, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                  <Grid ColumnDefinitions="*,Auto">
                    <Border Grid.Column="0" Background="#E0E0E0" CornerRadius="3" Height="6">
                      <Border CornerRadius="3" Height="6"
                              HorizontalAlignment="Left"
                              Width="{Binding PasswordStrengthWidth}"
                              Background="{Binding PasswordStrengthColor}"/>
                    </Border>
                    <TextBlock Grid.Column="1" Margin="8 0 0 0"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{Binding PasswordStrengthColor}"
                               Text="{Binding PasswordStrengthLabel}"/>
                  </Grid>
                </StackPanel>
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="{x:Static lang:Resources.ConfirmPassword}"/>
                <TextBox Text="{Binding ConfirmPassword}" PasswordChar="●"
                         Watermark="{x:Static lang:Resources.ConfirmNewPassword}"/>
              </StackPanel>

            </StackPanel>

            <!-- Step 2: Supervisor verification -->
            <StackPanel Spacing="10" IsVisible="{Binding IsStep2Visible}">
              <Border Background="#FFF8E1" CornerRadius="4" Padding="10">
                <TextBlock TextWrapping="Wrap" Foreground="#7B5800" FontStyle="Italic"
                           Text="{x:Static lang:Resources.SupervisorAuthNotice}"/>
              </Border>
              <StackPanel Spacing="4">
                <TextBlock Text="{x:Static lang:Resources.SupervisorUsername}"/>
                <TextBox Text="{Binding SupervisorUsername}"
                         Watermark="{x:Static lang:Resources.EnterSupervisorUsername}"/>
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="{x:Static lang:Resources.SupervisorPassword}"/>
                <TextBox Text="{Binding SupervisorPassword}" PasswordChar="●"
                         Watermark="{x:Static lang:Resources.EnterSupervisorPassword}"/>
              </StackPanel>
            </StackPanel>

            <!-- Feedback -->
            <TextBlock Foreground="Red" Text="{Binding ErrorMessage}"
                       IsVisible="{Binding HasError}" TextWrapping="Wrap"/>
            <TextBlock Foreground="Green" Text="{Binding SuccessMessage}"
                       IsVisible="{Binding HasSuccess}" TextWrapping="Wrap"/>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
              <Button Width="120" Command="{Binding ProceedToVerifyCommand}"
                      IsVisible="{Binding IsStep1Visible}"
                      Content="{x:Static lang:Resources.ButtonNext}"/>
              <Button Width="80" Command="{Binding BackCommand}"
                      IsVisible="{Binding IsStep2Visible}"
                      Content="{x:Static lang:Resources.ButtonBack}"/>
              <Button Width="130" Command="{Binding ConfirmResetCommand}"
                      IsVisible="{Binding IsStep2Visible}"
                      Content="{x:Static lang:Resources.ButtonConfirmReset}"/>
              <Button Width="100" Command="{Binding CancelCommand}"
                      Content="{x:Static lang:Resources.ButtonResetForm}"/>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

    </TabControl>
  </DockPanel>
</Window>
